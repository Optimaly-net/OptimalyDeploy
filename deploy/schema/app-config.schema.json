{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/Optimaly-net/OptimalyDeploy/deploy/schema/app-config.schema.json",
  "title": "OptimalyDeploy app config",
  "type": "object",
  "required": ["id", "server", "stackPath", "composeFile", "images", "services", "healthCheck"],
  "properties": {
    "id": { "type": "string", "pattern": "^[a-z0-9-]+$" },
    "projectCode": { "type": "string" },
    "environment": { "type": "string", "enum": ["production", "staging", "development"] },
    "server": { "type": "string" },
    "repository": { "type": "string" },
    "branch": { "type": "string", "default": "main" },
    "concurrencyGroup": { "type": "string" },
    "stackPath": { "type": "string" },
    "composeFile": { "type": "string", "default": "docker-compose.yml" },
    "versionVar": { "type": "string" },
    "composeProfiles": {
      "type": "array",
      "items": { "type": "string" }
    },
    "secretsFile": { "type": "string", "default": "secrets/.env" },
    "secretsFromEnv": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Environment variable names to upsert into secretsFile during deploy"
    },
    "secretMappings": {
      "type": "array",
      "description": "Copy secret values to alternate env var names (e.g. ASP.NET __ notation)",
      "items": {
        "type": "object",
        "required": ["from", "to"],
        "properties": {
          "from": { "type": "string" },
          "to": { "type": "string" }
        }
      }
    },
    "requiredSecrets": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Keys that must be non-empty in .env before compose up"
    },
    "envFile": {
      "type": "object",
      "properties": {
        "copyFrom": { "type": "string" },
        "copyTo": { "type": "string", "default": ".env" }
      }
    },
    "stackAssets": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["src", "dest"],
        "properties": {
          "src": { "type": "string" },
          "dest": { "type": "string" }
        }
      }
    },
    "images": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["name", "dockerfile", "context"],
        "properties": {
          "name": { "type": "string" },
          "dockerfile": { "type": "string" },
          "context": { "type": "string" },
          "buildArgs": {
            "type": "array",
            "items": { "type": "string" }
          }
        }
      }
    },
    "services": {
      "type": "array",
      "items": { "type": "string" },
      "minItems": 1
    },
    "healthCheck": {
      "type": "object",
      "required": ["url"],
      "properties": {
        "container": { "type": "string", "description": "Preferred: docker exec health check inside running container" },
        "network": { "type": "string" },
        "url": { "type": "string" },
        "hostHeader": { "type": "string" },
        "timeoutSeconds": { "type": "integer", "minimum": 1 },
        "minCode": { "type": "integer" },
        "maxCode": { "type": "integer" },
        "maxAttempts": { "type": "integer", "minimum": 1 },
        "retries": { "type": "integer", "minimum": 1 },
        "retryDelaySeconds": { "type": "integer", "minimum": 1 }
      }
    },
    "hooks": {
      "type": "object",
      "properties": {
        "preDeploy": { "type": "string" },
        "postDeploy": { "type": "string" }
      }
    },
    "postDeploy": {
      "type": "object",
      "properties": {
        "waitSeconds": { "type": "integer", "minimum": 0 },
        "pruneImagesHours": { "type": "integer", "minimum": 0 }
      }
    },
    "publicUrl": { "type": "string", "format": "uri" }
  }
}
